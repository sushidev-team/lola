<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="lola-desktop"
        Arguments=""
        InstallLocation="C:\Program Files\sushidev\lola">
    </Installer>
    <PackageInformation
        PackageName="lola"
        PackageDisplayName="lola"
        PublisherName="CN=sushidev"
        PublisherDisplayName="My Company"
        Version="0.1.0.0"
        PackageDescription="A lola-desktop application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="dev.sushi.lola.desktop"
                Description="A lola-desktop application"
                DisplayName="lola"
                ExecutableName="lola-desktop"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>lola</DisplayName>
            <PublisherDisplayName>sushidev</PublisherDisplayName>
            <Description>A lola-desktop application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="lola-desktop.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
